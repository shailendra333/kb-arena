# ─────────────────────────────────────────────────────────────────────────────
# KB-Arena environment configuration
# Copy this file to .env and fill in the values you need.
# Variables WITHOUT the KB_ARENA_ prefix are also accepted for Azure vars.
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider selection ────────────────────────────────────────────────────────
# LLM backend:       anthropic | openai | azure_openai | ollama
KB_ARENA_LLM_PROVIDER=azure_openai

# Embedding backend: openai | azure_openai | voyage | cohere | bge | ollama | gemini
KB_ARENA_EMBEDDING_PROVIDER=azure_openai

# ── Azure OpenAI — LLM / Chat ─────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://irisexpazureopenai.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# The deployment name to use for generate / fast / judge calls:
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
# Informational model name used only for cost estimation (e.g. gpt-4o, gpt-4.1):
AZURE_OPENAI_MODEL_NAME=gpt-4
# Optional: override deployment per role (falls back to AZURE_OPENAI_DEPLOYMENT_NAME)
# AZURE_OPENAI_GENERATE_DEPLOYMENT=gpt-4.1
# AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_JUDGE_DEPLOYMENT=gpt-4.1

# ── Azure OpenAI — Embeddings ─────────────────────────────────────────────────
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://irisexpazureopenai.openai.azure.com
# AZURE_OPENAI_EMBEDDING_API_VERSION=2025-01-01-preview   # defaults to AZURE_OPENAI_API_VERSION

# ── Neo4j ─────────────────────────────────────────────────────────────────────
KB_ARENA_NEO4J_URI=bolt://localhost:7687
KB_ARENA_NEO4J_USER=neo4j
KB_ARENA_NEO4J_PASSWORD=

# ── ChromaDB ──────────────────────────────────────────────────────────────────
KB_ARENA_CHROMA_PATH=./chroma_data

# ── Server ────────────────────────────────────────────────────────────────────
KB_ARENA_HOST=0.0.0.0
KB_ARENA_PORT=8000
KB_ARENA_DEBUG=false
# KB_ARENA_API_TOKEN=your-secret-token
# KB_ARENA_CORS_ORIGINS=["http://localhost:3000"]

# ── Anthropic (leave blank when using azure_openai provider) ─────────────────
# KB_ARENA_ANTHROPIC_API_KEY=

# ── Standard OpenAI (leave blank when using azure_openai provider) ────────────
# KB_ARENA_OPENAI_API_KEY=

# ── Benchmark ─────────────────────────────────────────────────────────────────
KB_ARENA_BENCHMARK_TEMPERATURE=0.0
KB_ARENA_BENCHMARK_MAX_CONCURRENT=5
KB_ARENA_BENCHMARK_COST_CAP_USD=10.0
